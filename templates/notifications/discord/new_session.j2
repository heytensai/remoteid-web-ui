{
  "embeds": [{
    "title": "New Flight Detected",
    "color": 3447003,
    "description": "{{ name|json_escape }} started a new flight{% if altitude is not none %} at {{ '%.0f' % (altitude if use_metric else altitude * 3.28084) }}{{ 'm' if use_metric else 'ft' }}{% endif %}",
    "fields": [
      {"name": "Drone", "value": "{{ name|json_escape }}", "inline": true},
      {"name": "Session", "value": "{{ session_id[:8]|json_escape }}", "inline": true}
      {% if altitude is not none -%}
      ,{"name": "Altitude", "value": "{{ '%.0f' % (altitude if use_metric else altitude * 3.28084) }}{{ 'm' if use_metric else 'ft' }}", "inline": true}
      {% endif -%}
      {% if height is not none -%}
      ,{"name": "Height{% if height_type %} ({{ height_type|json_escape }}){% endif %}", "value": "{{ '%.0f' % (height if use_metric else height * 3.28084) }}{{ 'm' if use_metric else 'ft' }}", "inline": true}
      {% endif -%}
    ],
    "timestamp": "{{ timestamp }}"{% if server_url %},
    "url": "{{ server_url }}"{% endif %}
  }]
}
